<UserControl x:Class="FolderLens.App.Views.SpaceSaverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FolderLens.App.Converters">
    <UserControl.Resources>
        <conv:SizeConverter x:Key="SizeConverter"/>
        <Style TargetType="TextBlock" x:Key="RightAligned">
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>

        <!-- Shared DataGrid Styles -->
        <Style TargetType="DataGridColumnHeader" x:Key="GridHeader">
            <Setter Property="Background" Value="#F7FAFC"/>
            <Setter Property="Foreground" Value="#718096"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="#EDF2F7"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F0F2F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🧹" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Space Saver" FontSize="16" FontWeight="SemiBold" Foreground="#1A202C" VerticalAlignment="Center"/>
                <TextBlock Text="Find duplicates, large files, and junk" FontSize="12" Foreground="#A0AEC0" 
                           Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tab Content -->
        <Border Grid.Row="1" Background="White" Margin="16" CornerRadius="8" 
                BorderBrush="#E2E8F0" BorderThickness="1">
            <TabControl Background="Transparent" BorderThickness="0" Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Foreground" Value="#718096"/>
                        <Setter Property="FontWeight" Value="Medium"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="Padding" Value="16,10"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder" Padding="{TemplateBinding Padding}" 
                                            Background="Transparent" BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                        <ContentPresenter ContentSource="Header"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="#4299E1"/>
                                            <Setter Property="Foreground" Value="#2B6CB0"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="#F7FAFC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <TabItem Header="🔁 Duplicates">
                    <DataGrid ItemsSource="{Binding Duplicates}" AutoGenerateColumns="False" 
                              Background="Transparent" BorderThickness="0" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EDF2F7"
                              HeadersVisibility="Column" CanUserAddRows="False"
                              RowBackground="White" AlternatingRowBackground="#F7FAFC"
                              Foreground="#2D3748" FontSize="12">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridHeader}"/>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EDF2F7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="HASH" Binding="{Binding Hash}" Width="180"/>
                            <DataGridTextColumn Header="WASTED" Binding="{Binding WastedSpace, Converter={StaticResource SizeConverter}}" Width="120" ElementStyle="{StaticResource RightAligned}"/>
                            <DataGridTextColumn Header="COPIES" Binding="{Binding Files.Count}" Width="80" ElementStyle="{StaticResource RightAligned}"/>
                            <DataGridTextColumn Header="FILE SIZE" Binding="{Binding Size, Converter={StaticResource SizeConverter}}" Width="100" ElementStyle="{StaticResource RightAligned}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="📦 Large Files">
                    <DataGrid ItemsSource="{Binding LargeFiles}" AutoGenerateColumns="False" 
                              Background="Transparent" BorderThickness="0" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EDF2F7"
                              HeadersVisibility="Column" CanUserAddRows="False"
                              RowBackground="White" AlternatingRowBackground="#F7FAFC"
                              Foreground="#2D3748" FontSize="12">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridHeader}"/>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EDF2F7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="280"/>
                            <DataGridTextColumn Header="SIZE" Binding="{Binding Size, Converter={StaticResource SizeConverter}}" Width="100" ElementStyle="{StaticResource RightAligned}"/>
                            <DataGridTextColumn Header="PATH" Binding="{Binding Path}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="🗑️ Developer Junk">
                    <DataGrid ItemsSource="{Binding DeveloperJunk}" AutoGenerateColumns="False" 
                              Background="Transparent" BorderThickness="0" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EDF2F7"
                              HeadersVisibility="Column" CanUserAddRows="False"
                              RowBackground="White" AlternatingRowBackground="#F7FAFC"
                              Foreground="#2D3748" FontSize="12">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridHeader}"/>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EDF2F7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="FOLDER" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="SIZE" Binding="{Binding Size, Converter={StaticResource SizeConverter}}" Width="100" ElementStyle="{StaticResource RightAligned}"/>
                            <DataGridTextColumn Header="PATH" Binding="{Binding Path}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Border>

        <!-- Loading overlay -->
        <Border Grid.Row="1" Background="#80FFFFFF" CornerRadius="8" Margin="16">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAnalyzing}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🔍" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Analyzing space savers..." FontSize="14" Foreground="#4A5568" FontWeight="Medium"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
