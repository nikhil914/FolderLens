<UserControl x:Class="FolderLens.App.Views.FileTypeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:conv="clr-namespace:FolderLens.App.Converters">
    <UserControl.Resources>
        <conv:SizeConverter x:Key="SizeConverter"/>
        <Style TargetType="TextBlock" x:Key="RightAligned">
            <Setter Property="HorizontalAlignment" Value="Right" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F0F2F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📊" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="File Type Analysis" FontSize="16" FontWeight="SemiBold" Foreground="#1A202C" VerticalAlignment="Center"/>
                <TextBlock Text="Breakdown by file category" FontSize="12" Foreground="#A0AEC0" 
                           Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Pie Chart -->
            <Border Background="White" CornerRadius="8" BorderBrush="#E2E8F0" BorderThickness="1" 
                    Margin="0,0,8,0" Padding="16">
                <oxy:PlotView Model="{Binding PieChartModel}"/>
            </Border>

            <!-- Data Table -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" BorderBrush="#E2E8F0" 
                    BorderThickness="1" Margin="8,0,0,0">
                <DataGrid ItemsSource="{Binding Categories}" AutoGenerateColumns="False" 
                          Background="Transparent" BorderThickness="0" 
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EDF2F7"
                          HeadersVisibility="Column" IsReadOnly="True" CanUserAddRows="False"
                          RowBackground="White" AlternatingRowBackground="#F7FAFC"
                          Foreground="#2D3748" FontSize="12">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F7FAFC"/>
                            <Setter Property="Foreground" Value="#718096"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="BorderBrush" Value="#EDF2F7"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="12,6"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EBF8FF"/>
                                    <Setter Property="Foreground" Value="#2B6CB0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EDF2F7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="CATEGORY" Binding="{Binding Category}" Width="*"/>
                        <DataGridTextColumn Header="FILES" Binding="{Binding FileCount, StringFormat={}{0:N0}}" Width="80" ElementStyle="{StaticResource RightAligned}"/>
                        <DataGridTextColumn Header="SIZE" Binding="{Binding TotalSize, Converter={StaticResource SizeConverter}}" Width="100" ElementStyle="{StaticResource RightAligned}"/>
                        <DataGridTextColumn Header="%" Binding="{Binding PercentageOfTotal, StringFormat={}{0:F1}%}" Width="60" ElementStyle="{StaticResource RightAligned}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
