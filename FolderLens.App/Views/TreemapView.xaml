<UserControl x:Class="FolderLens.App.Views.TreemapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FolderLens.App.Controls">
    <Grid Background="#F0F2F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="20,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🗂️" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Treemap Visualization" FontSize="16" FontWeight="SemiBold" Foreground="#1A202C" VerticalAlignment="Center"/>
                <TextBlock Text="Visual representation of folder sizes" FontSize="12" Foreground="#A0AEC0" 
                           Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Treemap -->
        <Border Grid.Row="1" Background="White" Margin="16" CornerRadius="8" 
                BorderBrush="#E2E8F0" BorderThickness="1" Padding="8">
            <controls:TreemapControl RootNode="{Binding CurrentRootNode}"/>
        </Border>
    </Grid>
</UserControl>
