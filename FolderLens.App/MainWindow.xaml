<Window x:Class="FolderLens.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FolderLens.App"
        xmlns:viewmodels="clr-namespace:FolderLens.App.ViewModels"
        xmlns:views="clr-namespace:FolderLens.App.Views"
        mc:Ignorable="d"
        Title="FolderLens" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">
    <Window.DataContext>
        <viewmodels:MainWindowViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewmodels:FolderAnalyzerViewModel}">
            <views:FolderAnalyzerView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:TreemapViewModel}">
            <views:TreemapView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:FileTypeViewModel}">
            <views:FileTypeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewmodels:SpaceSaverViewModel}">
            <views:SpaceSaverView />
        </DataTemplate>

        <!-- Sidebar Button Style -->
        <Style TargetType="Button" x:Key="SidebarButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4A5568"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="6" Margin="6,2" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EDF2F7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#CBD5E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="0" Background="#F0F2F5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- App Header -->
                    <StackPanel DockPanel.Dock="Top" Margin="16,20,16,24">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="FolderLens" FontSize="20" FontWeight="Bold" Foreground="#1A202C"/>
                        </StackPanel>
                        <TextBlock Text="Disk Usage Analyzer" FontSize="11" Foreground="#A0AEC0" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Navigation Separator -->
                    <TextBlock DockPanel.Dock="Top" Text="N A V I G A T I O N" FontSize="10" FontWeight="SemiBold" 
                               Foreground="#A0AEC0" Margin="22,0,0,8"/>

                    <!-- Bottom spacer -->
                    <TextBlock DockPanel.Dock="Bottom"/>

                    <!-- Navigation Buttons -->
                    <StackPanel>
                        <Button Content="📁  Folder Analyzer" Command="{Binding ShowFolderAnalyzerCommand}" Style="{StaticResource SidebarButton}"/>
                        <Button Content="🗂️  Treemap View" Command="{Binding ShowTreemapCommand}" Style="{StaticResource SidebarButton}"/>
                        <Button Content="📊  File Types" Command="{Binding ShowFileTypesCommand}" Style="{StaticResource SidebarButton}"/>
                        <Button Content="🧹  Space Saver" Command="{Binding ShowSpaceSaverCommand}" Style="{StaticResource SidebarButton}"/>
                        <Button Content="⚙️  Settings" IsEnabled="False" Style="{StaticResource SidebarButton}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Main Content -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="0"/>
        </Grid>
    </Border>
</Window>
